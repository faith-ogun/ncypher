# NCypher .gitignore
# Principle: commit ONLY code needed to run/reproduce the project.
# Everything else (data, secrets, metadata, docs, articles, video) stays local.

# ── Secrets & tokens — NEVER commit ──
other/
*.rtf
.env
*.pem
*.key
*token*
*secret*

# ── Large data & models — fetched, not committed ──
data/
models/
*.h5
*.pt
*.ckpt
*.npz
*.bigWig
*.bw
*.fa
*.fasta
*.fai

# ── Local-only: planning, docs, audit trail, metadata ──
docs/
CLAUDE.md
TODO.md
MEMORY.md
pmc.html

# ── Local-only: source articles (PDFs) and the rendered video project ──
articles/
video/

# ── Python ──
__pycache__/
*.py[cod]
.venv/
venv/
.ipynb_checkpoints/
*.egg-info/
.pytest_cache/

# ── Node / build output ──
node_modules/
dist/
.vite/

# ── Claude Code + OS/editor ──
.claude/*
!.claude/settings.json
!.claude/hooks/
.claude/settings.local.json

# Obsidian vault config (local second brain; folds into Onkydra post-hackathon)
.obsidian/

# Demo footage (large local clips + screenshots; not for the submission repo).
# The demo/ folder keeps only its docs (script/ + README + manifest); all the
# heavy video-editing media stays local: raw clips, the iMovie library (tens of
# GB), rendered scene MP4s / ProRes, VO audio, and OpenScreen project files.
# Several files exceed GitHub's 100MB per-file limit and cannot be pushed anyway.
demo/assets/
demo/scenes/
demo/NCypher.imovielibrary/
demo/openscreen project files/
*.imovielibrary/
.DS_Store
.vscode/
.idea/
.venv-mcp
.mcp-python/
